{% extends "material_base_common.html" %}
{% load my_templatetag %}
{% block breadcrumbs_items %}
{% load humanize %}
<a href="/">Home</a>
<a href="/redirect/apps">Applications</a>
<a href="/search_password/password" class="active">Password Manager</a>
{% endblock %}
{% block subcontent %}
{% include 'widgets/select_sort.html' %}
{% include 'widgets/loading.html' %}
{% include 'widgets/processing.html' %}

<div class="left-panel wide">

  <!-- ── TWO ACTION BUTTONS ── -->
  <div style="text-align:center; padding: 32px 0 8px;">
    {% if can_view %}
    <button class="waves-effect waves-light btn blue darken-3 pm-btn" id="btn-view" onclick="activatePanel('view')"
            style="border-radius:50px; margin:8px; padding:0 28px; font-weight:600; letter-spacing:0.4px;">
      <i class="material-icons left">visibility</i>View Passwords
    </button>
    {% endif %}
    {% if can_generate %}
    <button class="waves-effect waves-light btn green darken-3 pm-btn" id="btn-generate" onclick="activatePanel('generate')"
            style="border-radius:50px; margin:8px; padding:0 28px; font-weight:600; letter-spacing:0.4px;">
      <i class="material-icons left">add_circle_outline</i>Generate Password
    </button>
    {% endif %}
  </div>

  <!-- ── DYNAMIC PANEL (injected on click) ── -->
  <div id="pm-content-area"></div>

  <div id="celery">
    <br>
    {% include 'widgets/celery_background_jobs.html' %}
  </div>
  {% include 'widgets/keyboard_backspace.html' %}
</div>

<!-- view or export button javascript-->
{% include 'widgets/view_export.html' %}

<style>
  .pm-btn { transition: opacity 0.2s, transform 0.18s; }
  .pm-btn.pm-inactive { opacity: 0.45; transform: scale(0.97); }
  #pm-content-area .card { animation: pm-in 0.28s cubic-bezier(.4,0,.2,1) both; }
  @keyframes pm-in {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
</style>

<script>
  const CSRF = "{{ csrf_token }}";
  let activePanel = null;

  function viewPanelHTML() {
    return `
    <div class="card" id="form_div">
      <div class="card-content">
        <br/>
        <div class="row">
          <div id="search" class="col s12">
            <br>
            <form id="view-search-form" action="" method="post" novalidate onsubmit="submitViewForm(event)">
              <input type="hidden" name="csrfmiddlewaretoken" value="${CSRF}">
              <input type="hidden" name="mode" value="view">
              <div class="layout-row row">
                <div class="input-field col s12 m6">
                  <em class="material-icons prefix">event_note</em>
                  <input id="user_name" name="username" type="text">
                  <label class="active" for="user_name">User Name</label>
                </div>
                <div class="input-field col s12 m6">
                  <em class="material-icons prefix">event_note</em>
                  <input id="password" name="password" type="text">
                  <label for="password" class="active">Password</label>
                </div>
              </div>
              <br><br>
              <div class="right-align">
                <button class="waves-effect waves-light btn blue darken-3" type="submit"
                        style="border-radius:50px; padding:0 26px;">
                  <i class="material-icons left">search</i>Search
                </button>
              </div>
            </form>
            <div id="view-results"></div>
          </div>
        </div>
      </div>
    </div>`;
  }

  function generatePanelHTML() {
    return `
    <div class="card" id="form_div">
      <div class="card-content">
        <br/>
        <div class="row">
          <div id="search" class="col s12">
            <br>
            <form id="generate-form" action="" method="post" novalidate>
              <input type="hidden" name="csrfmiddlewaretoken" value="${CSRF}">
              <input type="hidden" name="mode" value="generate">
              <div class="layout-row row">
                <div class="input-field col s12 m6">
                  <em class="material-icons prefix">event_note</em>
                  <input id="user_name" name="username" type="text">
                  <label class="active" for="user_name">User Name</label>
                </div>
                <div class="input-field col s12 m6">
                  <em class="material-icons prefix">event_note</em>
                  <input id="password" name="password" type="text">
                  <label for="password" class="active">Password</label>
                </div>
              </div>
              <br><br>
              <div class="right-align">
                <button class="waves-effect waves-light btn green darken-3" type="submit"
                        style="border-radius:50px; padding:0 26px;">
                  <i class="material-icons left">save</i>Generate &amp; Save
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>`;
  }

  function activatePanel(panel) {
    const area = document.getElementById('pm-content-area');
    const btnV = document.getElementById('btn-view');
    const btnG = document.getElementById('btn-generate');

    if (activePanel === panel) {
      area.innerHTML = '';
      activePanel = null;
      if (btnV) btnV.classList.remove('pm-inactive');
      if (btnG) btnG.classList.remove('pm-inactive');
      return;
    }

    activePanel = panel;
    if (btnV) btnV.classList.toggle('pm-inactive', panel !== 'view');
    if (btnG) btnG.classList.toggle('pm-inactive', panel !== 'generate');

    area.innerHTML = panel === 'view' ? viewPanelHTML() : generatePanelHTML();
    if (typeof M !== 'undefined') M.updateTextFields();
    area.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* AJAX search — falls back to normal submit if backend not ready */
  function submitViewForm(e) {
    e.preventDefault();
    const form = document.getElementById('view-search-form');
    const results = document.getElementById('view-results');
    results.innerHTML = `<div style="text-align:center;padding:24px">
      <div class="preloader-wrapper small active">
        <div class="spinner-layer spinner-blue-only">
          <div class="circle-clipper left"><div class="circle"></div></div>
          <div class="gap-patch"><div class="circle"></div></div>
          <div class="circle-clipper right"><div class="circle"></div></div>
        </div>
      </div></div>`;

    fetch(window.location.href, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(json => renderResults(json.creds))
    .catch(() => form.submit());
  }

  function renderResults(creds) {
    const results = document.getElementById('view-results');
    if (!creds || !creds.length) {
      results.innerHTML = `<p class="center-align grey-text" style="padding:24px 0">No credentials found.</p>`;
      return;
    }
    const rows = creds.map(c => `<tr>
      <td>${c.username}</td>
      <td>${c.password_enc}</td>
      <td>${c.owner}</td>
      <td>${c.created_at}</td>
    </tr>`).join('');
    results.innerHTML = `<br>
      <table class="highlight responsive-table">
        <thead><tr>
          <th>Username</th><th>Password</th><th>Owner</th><th>Created At</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
  }
</script>

{% endblock %}
