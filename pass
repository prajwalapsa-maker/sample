{% extends "material_base_common.html" %}
{% load my_templatetag %}
{% block breadcrumbs_items %}
{% load humanize %}
<a href="/">Home</a>
<a href="/redirect/apps">Applications</a>
<a href="/search_password/password" class="active">Password Manager</a>
{% endblock %}
{% block subcontent %}
{% include 'widgets/select_sort.html' %}
{% include 'widgets/loading.html' %}
{% include 'widgets/processing.html' %}

<div class="left-panel wide">

  <!-- ── TWO ACTION BUTTONS ── -->
  <div style="text-align:center; padding: 32px 0 8px;">
    {% if can_view %}
    <a href="{% url 'password_manager:cred_list' %}"
       class="waves-effect waves-light btn blue darken-3 pm-btn" id="btn-view"
       style="border-radius:50px; margin:8px; padding:0 28px; font-weight:600; letter-spacing:0.4px;">
      <i class="material-icons left">visibility</i>View Passwords
    </a>
    {% endif %}
    {% if can_generate %}
    <button class="waves-effect waves-light btn green darken-3 pm-btn" id="btn-generate"
            onclick="activatePanel()"
            data-action="{% url 'password_manager:cred_new' %}"
            style="border-radius:50px; margin:8px; padding:0 28px; font-weight:600; letter-spacing:0.4px;">
      <i class="material-icons left">add_circle_outline</i>Generate Password
    </button>
    {% endif %}
  </div>

  <!-- ── GENERATE PANEL (injected on click) ── -->
  <div id="pm-content-area"></div>

  <div id="celery">
    <br>
    {% include 'widgets/celery_background_jobs.html' %}
  </div>
  {% include 'widgets/keyboard_backspace.html' %}
</div>

{% include 'widgets/view_export.html' %}

<style>
  .pm-btn { transition: opacity 0.2s, transform 0.18s; }
  .pm-btn.pm-inactive { opacity: 0.45; transform: scale(0.97); }
  #pm-content-area .card { animation: pm-in 0.28s cubic-bezier(.4,0,.2,1) both; }
  @keyframes pm-in {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
</style>

<script>
  const CSRF = "{{ csrf_token }}";
  let panelOpen = false;

  function generatePanelHTML() {
    return `
    <div class="card" id="form_div">
      <div class="card-content">
        <br/>
        <div class="row">
          <div id="search" class="col s12">
            <br>
            <form id="generate-form" action="" method="post" novalidate onsubmit="setFormAction(this)">
              <input type="hidden" name="csrfmiddlewaretoken" value="${CSRF}">
              <input type="hidden" name="mode" value="generate">
              <!-- action is set by JS below since this is injected dynamically -->
              <div class="layout-row row">
                <div class="input-field col s12 m6">
                  <em class="material-icons prefix">event_note</em>
                  <input id="user_name" name="username" type="text">
                  <label class="active" for="user_name">User Name</label>
                </div>
                <div class="input-field col s12 m6">
                  <em class="material-icons prefix">event_note</em>
                  <input id="password" name="password" type="text">
                  <label for="password" class="active">Password</label>
                </div>
              </div>
              <br><br>
              <div class="right-align">
                <button class="waves-effect waves-light btn green darken-3" type="submit"
                        style="border-radius:50px; padding:0 26px;">
                  <i class="material-icons left">save</i>Generate &amp; Save
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>`;
  }

  function setFormAction(form) {
    form.action = document.getElementById('btn-generate').dataset.action;
  }

  function activatePanel() {
    const area = document.getElementById('pm-content-area');
    const btnV = document.getElementById('btn-view');
    const btnG = document.getElementById('btn-generate');

    if (panelOpen) {
      // collapse
      area.innerHTML = '';
      panelOpen = false;
      if (btnV) btnV.classList.remove('pm-inactive');
      if (btnG) btnG.classList.remove('pm-inactive');
      return;
    }

    panelOpen = true;
    if (btnV) btnV.classList.add('pm-inactive');

    area.innerHTML = generatePanelHTML();
    if (typeof M !== 'undefined') M.updateTextFields();
    area.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>

{% endblock %}
